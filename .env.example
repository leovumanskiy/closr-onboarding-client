# ─── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...  # NEVER expose client-side

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# ─── Production (Vercel) ──────────────────────────────────────────────────────
# NEXT_PUBLIC_APP_URL=https://onboarding-five-mauve.vercel.app
# NEXTAUTH_URL=https://onboarding-five-mauve.vercel.app
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-32-byte-secret-here

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=onboarding@yourdomain.com

# ─── Slack ────────────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
SLACK_BOT_TOKEN=xoxb-your-bot-token          # Required for per-client channel DMs
SLACK_ESCALATION_WEBHOOK_URL=               # Optional: separate webhook for Ville & Lane escalations (falls back to SLACK_WEBHOOK_URL)

# ─── n8n webhooks (Slack DMs are routed via n8n) ─────────────────────────────
# n8n workflow should call Slack chat.postMessage and return the API JSON
# response via "Respond to Webhook" so we can verify delivery (ok/channel/ts).
N8N_WEBHOOK_WELCOME=                        # Triggered during force-password — sends welcome DM, must succeed before login
N8N_WEBHOOK_APPROACHING=                    # Triggered for 24h-due reminders
N8N_WEBHOOK_OVERDUE=                        # Triggered for overdue reminders
N8N_WEBHOOK_MODULE_COMPLETE=                # Triggered when a module is completed

# ─── Cron ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
CRON_SECRET=your-cron-secret-here

# ─── Secrets encryption ───────────────────────────────────────────────────────
# Encrypts third-party tokens (e.g. GHL API keys) at rest in the DB.
# Generate with: openssl rand -base64 32
# REQUIRED in production. Rotating this makes existing encrypted tokens
# unreadable (clients must reconnect GHL).
SECRETS_ENC_KEY=your-32-byte-secret-here

# ─── Integrations (optional) ──────────────────────────────────────────────────
CALENDLY_URL=               # Calendly/Cal.com embed URL for booking steps
